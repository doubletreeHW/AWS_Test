{
  "family": "aws-test-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "aws-test-container",
      "image": "579920977714.dkr.ecr.ap-northeast-2.amazonaws.com/aws-test-repo:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aws-test-task",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::579920977714:role/ecsTaskExecutionRole"
}
